generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📦 PRODUTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Product {
  id            String   @id @default(cuid())
  shortId       Int      @unique @default(autoincrement()) // ID numérico curto para URLs
  name          String
  category      String
  subcategory   String?  // Subcategoria para recomendações granulares (ex: "Smartphones" dentro de "Smartphones e TV")
  brand         String?  // Marca do produto (Apple, Samsung, Xiaomi...)
  model         String?  // Modelo específico (iPhone 15 Pro, Galaxy S24...)
  storeName     String?  // Nome da loja de origem (Amazon, Mercado Livre...)
  platformProductId String? // ID do produto na plataforma original (ASIN, MLB-xxx, ShopeeID)
  description   String?  // Descrição do produto
  imageUrl      String   // URL da imagem principal
  price         Float?
  originalPrice Float?
  status        String   @default("pending") // pending, active, rejected
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relações existentes (mantidas intactas)
  links         Link?
  coupons       Coupon[]
  priceHistory  PriceHistory[]
  clickLogs     ClickLog[]
  comments      Comment[]
  votes         ProductVote[]
  alerts        ProductAlert[]

  // IA e Analytics
  aiScore          Float?   // Nota de 0 a 10 dada pela IA
  aiAnalysis       String?  // Texto/Copy gerado pela IA
  clicks           Int      @default(0)
  externalId       String?  @unique // Hash de deduplicação
  enhancedImageUrl String?  // Imagem aprimorada
  isFixed          Boolean  @default(false) // Trava dados contra sobrescrita do robô

  // Flags de processamento (evita reprocessar o que já foi feito)
  aiProcessed        Boolean  @default(false) // true = IA já rodou com sucesso
  aiProcessedAt      DateTime? // quando a IA processou pela última vez
  affiliateProcessed Boolean  @default(false) // true = links de afiliado já foram gerados

  // NOVOS — Reviews
  reviewScore        Float?   // média de estrelas (ex: 4.5)
  reviewCount        Int?     // quantidade de avaliações
  reviews            ProductReview[]

  // Novas relações
  images        ProductImage[]
  productLinks  ProductLink[]
  favorites     UserFavorite[]

  @@index([category])
  @@index([subcategory])
  @@index([brand])
  @@index([platformProductId])
  @@index([storeName])
  @@index([createdAt])
  @@index([status])
  @@index([externalId])
  @@index([shortId])
  @@index([aiProcessed])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📈 HISTÓRICO DE PREÇOS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Float
  originalPrice Float?
  createdAt   DateTime @default(now())
  
  @@index([productId, createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖱️ RASTREAMENTO DE CLIQUES (ANALYTICS)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model ClickLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userAgent   String?  // Navegador/Dispositivo do usuário
  referrer    String?  // De onde veio o clique (Telegram, WhatsApp, Insta)
  channel     String?  // Canal explícito se passado na URL (ex: ?ch=tg)
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@index([channel])
  @@index([createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔗 LINKS DE AFILIADOS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔗 LINKS LEGADOS (mantido para compatibilidade — não remover)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Link {
  id           String  @id @default(cuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  amazon       String?
  aliexpress   String?
  shopee       String?
  mercadoLivre String?
  tiktok       String?
  netshoes     String?
  magalu       String?
  kabum        String?
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔗 LINKS EXPANDIDOS (novo modelo — separa original, afiliado e gerado)
// Critério de remoção do Link legado: após 4 semanas com ProductLink
// 100% populado para produtos novos + zero erros no admin + backfill completo
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model ProductLink {
  id                    String   @id @default(cuid())
  productId             String
  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform              String   // "amazon", "mercadoLivre", "shopee", "aliexpress", "tiktok", "magalu", "kabum", "netshoes"
  sourceUrl             String?  @db.Text // URL original da plataforma (ANTES de qualquer tag de afiliado)
  affiliateUrl          String?  @db.Text // Link enviado pelo bot (pode já ter tag do parceiro)
  generatedAffiliateUrl String?  @db.Text // Link gerado pelo nosso sistema (com nossa própria tag)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([productId, platform])
  @@index([productId])
  @@index([platform])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖼️ GALERIA DE IMAGENS DO PRODUTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String   @db.Text // URL da imagem
  source    String?  // "scraper", "enhanced", "upload", "retailer", "bot"
  isPrimary Boolean  @default(false) // Imagem principal
  order     Int      @default(0) // Ordem na galeria
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([productId, isPrimary])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 💬 AVALIAÇÕES DO PRODUTO (REVIEWS)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model ProductReview {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  platform    String   // "mercadolivre", "amazon", "shopee"
  authorName  String?
  rating      Float    // 1-5
  comment     String?  @db.Text
  helpful     Int      @default(0)  // quantidade de "útil"
  verified    Boolean  @default(false)
  externalId  String?  // ID do review na plataforma
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  
  @@unique([productId, platform, externalId])
  @@index([productId])
  @@index([platform])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ❤️ FAVORITOS DO USUÁRIO (com snapshot de subcategoria para recomendações)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model UserFavorite {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  subcategory String?  // snapshot da subcategoria no momento do favorito
  category    String?  // snapshot da categoria no momento do favorito
  brand       String?  // snapshot da marca
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([userId, subcategory])
  @@index([userId, category])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🎫 CUPONS DE DESCONTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Coupon {
  id          String   @id @default(cuid())
  code        String   // Código do cupom (ex: DESCONTO10)
  description String   // Descrição pode ser longa
  discount    String   // Valor do desconto (ex: "10% OFF")
  platform    String   // Plataforma (Amazon, Shopee, etc)
  productId   String?  // Opcional: cupom específico para um produto
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? // Data de expiração (opcional)
  isActive    Boolean  @default(true) // Ativo/Inativo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([platform])
  @@index([isActive])
  @@index([expiresAt])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖼️ BANNERS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Banner {
  id           String   @id @default(cuid())
  title        String
  imageDesktop String   // URL da imagem para desktop
  imageMobile  String   // URL da imagem para mobile
  link         String?  // Link ao clicar no banner
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔔 PUSH SUBSCRIPTIONS (NOTIFICAÇÕES)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique // URL do endpoint de push
  p256dh      String   // Chave pública do cliente
  auth        String   // Chave de autenticação
  userId      String?  // NOVO - opcional para associar a um usuário logado
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences Json?    // Preferências de alerta (ex: categorias selecionadas)
  createdAt   DateTime @default(now())
  
  @@index([endpoint])
  @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 👤 USUÁRIOS E AUTENTICAÇÃO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?  // Hashed password (null for Google-only users)
  image     String?  // URL da imagem de perfil (ex: Google avatar)
  googleId  String?  @unique // ID do Google para OAuth
  role      String   @default("user") // "user", "moderator", "admin"
  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  engagementScore Int @default(0)
  telegramId String? @unique // NOVO — Telegram ID para alertas
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments     Comment[]
  votes        ProductVote[]
  alerts       ProductAlert[]
  activityLogs ActivityLog[]
  tags         UserTagAssignment[]
  notes        UserNote[]
  favorites    UserFavorite[]
  pushSubscriptions PushSubscription[] // NOVO — Push subscriptions do usuário

  @@index([email])
  @@index([googleId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 💬 COMENTÁRIOS E AVALIAÇÕES
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Comment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, createdAt])
}

model ProductVote {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "LIKE" ou "DISLIKE"
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

model ProductAlert {
  id             String    @id @default(cuid())
  productId      String
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  threshold      Float?    // % mínima de queda para notificar (ex: 5.0 = 5%)
  channel        String    @default("telegram") // "telegram", "push", "both"
  lastNotifiedAt DateTime? // evita spam — não notifica 2x no mesmo dia
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📝 LOG DE ATIVIDADES (AUDIT TRAIL) E CRM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  details     String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model UserTag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")
  users UserTagAssignment[]
}

model UserTagAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId     String
  tag       UserTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tagId])
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorId  String?
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📢 CAMPANHAS (Push, Telegram, WhatsApp)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Campaign {
  id              String    @id @default(cuid())
  title           String
  message         String    @db.Text
  channel         String    // "push" | "telegram" | "whatsapp"
  status          String    @default("draft") // "draft" | "scheduled" | "sending" | "sent" | "failed"
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalTargets    Int       @default(0)
  totalSent       Int       @default(0)
  totalFailed     Int       @default(0)
  metadata        String?   @db.Text // JSON com campos extras por canal
  authorId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([channel])
  @@index([status])
  @@index([scheduledAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🤝 PARCEIROS E SISTEMA
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Partner {
  id             String   @id @default(cuid())
  name           String
  email          String?
  platform       String
  channelName    String?
  trackingCode   String   @unique
  totalClicks    Int      @default(0)
  totalRevenue   Float    @default(0)
  commissionRate Float    @default(0)
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([trackingCode])
  @@index([platform])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🧠 IA CRIATIVA — Histórico, Feedback e Controle de Prompt
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Histórico de Legendas Geradas pela IA
model CaptionHistory {
  id            String    @id @default(cuid())
  productId     String?   // null se o produto for deletado
  productName   String    // snapshot do nome do produto
  caption       String    @db.Text // o texto da legenda gerada
  score         Float?    // nota do aiScore (0-10)
  rating        Int?      // sua nota: 1=ruim, 2=ok, 3=boa, 4=ótima, 5=perfeita
  ratedAt       DateTime?
  usedAsExample Boolean   @default(false) // se foi aprovado para ser exemplo no prompt
  createdAt     DateTime  @default(now())

  @@index([productId])
  @@index([rating])
  @@index([usedAsExample])
  @@index([createdAt])
}

// Palavras Bloqueadas — a IA nunca deve usar
model AiBannedWord {
  id        String   @id @default(cuid())
  word      String   @unique
  reason    String?  // ex: "errado gramaticalmente", "ofensivo", "já usado demais"
  createdAt DateTime @default(now())

  @@index([word])
}

// Substituições de Palavras — pós-processamento após geração
model AiWordSubstitution {
  id        String   @id @default(cuid())
  fromWord  String   @unique // palavra a substituir (ex: "nenem")
  toWord    String           // palavra substituta (ex: "bebê")
  createdAt DateTime @default(now())

  @@index([fromWord])
}

// Contextos / Eventos Temporais — injetados dinamicamente no prompt
model AiContext {
  id          String    @id @default(cuid())
  title       String    // ex: "Copa do Mundo 2026", "Dia dos Pais"
  description String    @db.Text // o texto que será injetado no prompt
  isActive    Boolean   @default(true)
  startsAt    DateTime? // quando começa a valer (null = sempre)
  endsAt      DateTime? // quando expira (null = sem prazo)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([startsAt])
  @@index([endsAt])
}
