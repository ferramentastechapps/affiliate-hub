generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📦 PRODUTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Product {
  id          String   @id @default(cuid())
  name        String
  category    String
  description String?  // URLs e textos longos
  imageUrl    String   // URLs podem ser muito longas
  price       Float?
  originalPrice Float?
  status      String   @default("pending") // pending, active, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  links       Link?
  coupons     Coupon[]
  
  @@index([category])
  @@index([createdAt])
  @@index([status])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔗 LINKS DE AFILIADOS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Link {
  id           String  @id @default(cuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  amazon       String? // URLs de afiliado podem ser muito longas
  aliexpress   String?
  shopee       String?
  mercadoLivre String?
  tiktok       String?
  netshoes     String?
  magalu       String?
  kabum        String?
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🎫 CUPONS DE DESCONTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Coupon {
  id          String   @id @default(cuid())
  code        String   // Código do cupom (ex: DESCONTO10)
  description String   // Descrição pode ser longa
  discount    String   // Valor do desconto (ex: "10% OFF")
  platform    String   // Plataforma (Amazon, Shopee, etc)
  productId   String?  // Opcional: cupom específico para um produto
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? // Data de expiração (opcional)
  isActive    Boolean  @default(true) // Ativo/Inativo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([platform])
  @@index([isActive])
  @@index([expiresAt])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖼️ BANNERS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Banner {
  id           String   @id @default(cuid())
  title        String
  imageDesktop String   // URL da imagem para desktop
  imageMobile  String   // URL da imagem para mobile
  link         String?  // Link ao clicar no banner
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔔 PUSH SUBSCRIPTIONS (NOTIFICAÇÕES)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique // URL do endpoint de push
  p256dh      String   // Chave pública do cliente
  auth        String   // Chave de autenticação
  createdAt   DateTime @default(now())
  
  @@index([endpoint])
}
