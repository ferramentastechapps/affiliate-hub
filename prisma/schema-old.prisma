generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📦 PRODUTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Product {
  id          String   @id @default(cuid())
  shortId     Int      @unique @default(autoincrement()) // ID numérico curto para URLs
  name        String
  category    String
  description String?  // URLs e textos longos
  imageUrl    String   // URLs podem ser muito longas
  price       Float?
  originalPrice Float?
  status      String   @default("pending") // pending, active, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  links       Link?
  coupons     Coupon[]
  priceHistory PriceHistory[]
  clickLogs   ClickLog[]
  
  // Novos campos para IA e Analytics
  aiScore     Float?   // Nota de 0 a 10 dada pela IA
  aiAnalysis  String?  // Texto/Copy gerado pela IA
  clicks      Int      @default(0) // Quantidade de cliques
  externalId  String?  @unique // Hash ou ID original para deduplicação segura
  enhancedImageUrl String? // Imagem processada pela IA (Fundo/4K)
  isFixed     Boolean  @default(false) // Trava a imagem e os links para não serem sobrescritos pelo robô
  
  comments    Comment[]
  votes       ProductVote[]
  alerts      ProductAlert[]

  @@index([category])
  @@index([createdAt])
  @@index([status])
  @@index([externalId])
  @@index([shortId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📈 HISTÓRICO DE PREÇOS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       Float
  originalPrice Float?
  createdAt   DateTime @default(now())
  
  @@index([productId, createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖱️ RASTREAMENTO DE CLIQUES (ANALYTICS)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model ClickLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userAgent   String?  // Navegador/Dispositivo do usuário
  referrer    String?  // De onde veio o clique (Telegram, WhatsApp, Insta)
  channel     String?  // Canal explícito se passado na URL (ex: ?ch=tg)
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@index([channel])
  @@index([createdAt])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔗 LINKS DE AFILIADOS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Link {
  id           String  @id @default(cuid())
  productId    String  @unique
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  amazon       String? // URLs de afiliado podem ser muito longas
  aliexpress   String?
  shopee       String?
  mercadoLivre String?
  tiktok       String?
  netshoes     String?
  magalu       String?
  kabum        String?
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🎫 CUPONS DE DESCONTO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Coupon {
  id          String   @id @default(cuid())
  code        String   // Código do cupom (ex: DESCONTO10)
  description String   // Descrição pode ser longa
  discount    String   // Valor do desconto (ex: "10% OFF")
  platform    String   // Plataforma (Amazon, Shopee, etc)
  productId   String?  // Opcional: cupom específico para um produto
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  expiresAt   DateTime? // Data de expiração (opcional)
  isActive    Boolean  @default(true) // Ativo/Inativo
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([platform])
  @@index([isActive])
  @@index([expiresAt])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🖼️ BANNERS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Banner {
  id           String   @id @default(cuid())
  title        String
  imageDesktop String   // URL da imagem para desktop
  imageMobile  String   // URL da imagem para mobile
  link         String?  // Link ao clicar no banner
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🔔 PUSH SUBSCRIPTIONS (NOTIFICAÇÕES)
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model PushSubscription {
  id          String   @id @default(cuid())
  endpoint    String   @unique // URL do endpoint de push
  p256dh      String   // Chave pública do cliente
  auth        String   // Chave de autenticação
  createdAt   DateTime @default(now())
  
  @@index([endpoint])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 👤 USUÁRIOS E AUTENTICAÇÃO
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?  // Hashed password (null for Google-only users)
  image     String?  // URL da imagem de perfil (ex: Google avatar)
  googleId  String?  @unique // ID do Google para OAuth
  role      String   @default("user") // "user", "moderator", "admin"
  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  engagementScore Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments  Comment[]
  votes     ProductVote[]
  alerts    ProductAlert[]
  activityLogs ActivityLog[]
  tags      UserTagAssignment[]
  notes     UserNote[]

  @@index([email])
  @@index([googleId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 💬 COMENTÁRIOS E AVALIAÇÕES
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
model Comment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestName String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, createdAt])
}

model ProductVote {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "LIKE" ou "DISLIKE"
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

model ProductAlert {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 📝 LOG DE ATIVIDADES (AUDIT TRAIL) E CRM
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String?
  details     String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model UserTag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")
  users UserTagAssignment[]
}

model UserTagAssignment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId     String
  tag       UserTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, tagId])
}

model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  authorId  String?
  text      String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 🤝 PARCEIROS E SISTEMA
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

model Partner {
  id             String   @id @default(cuid())
  name           String
  email          String?
  platform       String
  channelName    String?
  trackingCode   String   @unique
  totalClicks    Int      @default(0)
  totalRevenue   Float    @default(0)
  commissionRate Float    @default(0)
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([trackingCode])
  @@index([platform])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([key])
}
